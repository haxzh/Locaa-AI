# Locaa AI .env Configuration Template v2.5

# ==================== FLASK & DATABASE ====================
FLASK_ENV=development
FLASK_DEBUG=true
DATABASE_URL=sqlite:///locaa_ai.db
# For PostgreSQL: postgresql://user:password@localhost:5432/locaa_ai

# ==================== JWT & SECURITY ====================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=86400

# ==================== VIDEO PROCESSING ====================
YOUTUBE_API_KEY=your_youtube_api_key_here
FFMPEG_PATH=/usr/bin/ffmpeg

# ==================== AI IMAGE GENERATION (STABILITY AI - FREE!) ====================
# Get FREE Stability AI key from: https://platform.stability.ai/account/api-key
# Free tier: 25 images/day, high quality, no credit card required for sign-up!
STABILITY_API_KEY=sk_your_stability_ai_key_here_xxxxxxxxxxxxxxxxxxxx

# ==================== AI VIDEO GENERATION (REPLICATE) ====================
# Get Replicate token from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_token_here_xxxxxxxxxxxxxxxxxxxx
REPLICATE_VIDEO_MODEL_VERSION=39492613382246ba612e06f4d91646ba9b693126b0a8801b9e2fc5c9629ebd48

# ==================== STORAGE ====================
UPLOAD_FOLDER=backend/uploads
MAX_VIDEO_SIZE=536870912  # 500MB in bytes
ALLOWED_EXTENSIONS=mp4,avi,mov,mkv,flv,wmv,webm

# ==================== STRIPE PAYMENT ====================
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ==================== EMAIL CONFIGURATION ====================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_DEFAULT_SENDER=noreply@locaaai.com

# Email settings
EMAIL_VERIFICATION_EXPIRY=86400  # 24 hours
PASSWORD_RESET_EXPIRY=7200  # 2 hours
SEND_WELCOME_EMAIL=true
SEND_COMPLETION_EMAILS=true

# ==================== INSTAGRAM INTEGRATION ====================
INSTAGRAM_ACCESS_TOKEN=your_instagram_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id
INSTAGRAM_API_VERSION=v18.0

# ==================== TIKTOK INTEGRATION ====================
TIKTOK_API_KEY=your_tiktok_api_key
TIKTOK_SECRET_KEY=your_tiktok_secret_key
TIKTOK_ACCESS_TOKEN=your_tiktok_token

# ==================== AWS S3 (OPTIONAL) ====================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=locaa-ai-videos
AWS_S3_REGION=us-east-1

# ==================== REDIS (FOR CACHING & QUEUE) ====================
REDIS_URL=redis://localhost:6379/0

# ==================== CELERY (BACKGROUND TASKS) ====================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=10

# ==================== FRONTEND ====================
FRONTEND_URL=http://localhost:5173
FRONTEND_BUILD_DIR=frontend/dist

# ==================== API CONFIGURATION ====================
API_RATE_LIMIT_ENABLED=true
CORS_ORIGINS=*
MAX_CONTENT_LENGTH=536870912  # 500MB

# ==================== ADMIN ====================
ADMIN_EMAIL=admin@locaaai.com
ADMIN_PASSWORD=change_me_in_production

# ==================== SUBSCRIPTION SETTINGS ====================
FREE_TIER_VIDEOS_PER_MONTH=5
FREE_TIER_CLIPS_PER_VIDEO=3

PRO_TIER_VIDEOS_PER_MONTH=30
PRO_TIER_CLIPS_PER_VIDEO=10
PRO_TIER_PRICE_MONTHLY=2900  # in cents
PRO_TIER_PRICE_YEARLY=29000

BUSINESS_TIER_VIDEOS_PER_MONTH=999
BUSINESS_TIER_CLIPS_PER_VIDEO=999
BUSINESS_TIER_PRICE_MONTHLY=9900
BUSINESS_TIER_PRICE_YEARLY=99000

# ==================== BATCH PROCESSING ====================
BATCH_MAX_VIDEOS_FREE=0
BATCH_MAX_VIDEOS_PRO=10
BATCH_MAX_VIDEOS_BUSINESS=1000
ENABLE_PARALLEL_PROCESSING=true
MAX_PARALLEL_JOBS=3

# ==================== SCHEDULED PUBLISHING ====================
ENABLE_SCHEDULED_PUBLISHING=true
SCHEDULED_CHECK_INTERVAL=300  # Check every 5 minutes
TIMEZONE=UTC

# ==================== WATERMARK SETTINGS ====================
WATERMARK_MAX_SIZE=5242880  # 5MB
WATERMARK_ALLOWED_FORMATS=png,jpg,jpeg,gif
WATERMARK_DEFAULT_OPACITY=0.8
WATERMARK_DEFAULT_SCALE=1.0

# ==================== ANALYTICS ====================
ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90
TRACK_USER_BEHAVIOR=true

# ==================== SECURITY ====================
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL_CHARS=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_UPPERCASE=true

# ==================== RATE LIMITING ====================
ENABLE_RATE_LIMITING=true
RATE_LIMIT_STORAGE=redis  # or memory
RATE_LIMIT_RESET_INTERVAL=3600  # 1 hour

# ==================== MONITORING ====================
ENABLE_SENTRY=false
SENTRY_DSN=your_sentry_dsn_here
ENABLE_PROMETHEUS=false

# ==================== DEVELOPMENT ====================
ENABLE_MOCK_PAYMENT=false
ENABLE_TEST_MODE=false
DEBUG_SQL_QUERIES=false
UPLOAD_DIR=backend/uploads/
VIDEO_DIR=videos/
CREDENTIALS_DIR=backend/credentials/
